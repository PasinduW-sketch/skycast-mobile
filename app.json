{
  "expo": {
    "name": "SkyCast",
    "slug": "skycast",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "backgroundColor": "#4a90d9"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SkyCast needs your location to show weather for your current area."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#4a90d9",
        "foregroundImage": "./assets/splash-icon.png"
      },
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"],
      "package": "com.skycast.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "SkyCast needs your location to show weather for your current area."
        }
      ]
    ]
  }
}
